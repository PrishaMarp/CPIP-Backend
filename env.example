# Project Settings -> API -> Project URL
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Project Settings -> API -> Project API keys -> service_role (SECRET, never put this in the iOS app)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# A secret string you make up. The iOS app must send this in the
# X-API-Key header on every request.
API_KEY=choose-a-long-random-string

# Optional: enable LLM-backed Stage 1 extraction.
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
